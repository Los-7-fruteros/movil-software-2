{
  "expo": {
    "name": "AgroMonitor",
    "slug": "reservoir-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF5F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reservoirmonitor.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EBF5FF"
      },
      "package": "com.reservoirmonitor.app",
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-web-browser"
    ],
    "scheme": "reservoirmonitor",
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "1fbe55a1-9166-49fb-b2fb-1943ebc087d2"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1fbe55a1-9166-49fb-b2fb-1943ebc087d2"
    },
    "owner": "javiercancinounab"
  }
}
